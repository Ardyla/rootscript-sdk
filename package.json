{
  "name": "rootscript-sdk",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm --filter @ardyla/rootscript-core build",
    "test": "pnpm --filter @ardyla/rootscript-core test",
    "typecheck": "pnpm --filter @ardyla/rootscript-core typecheck",
    "release:core": "pnpm --filter @ardyla/rootscript-core build && pnpm --filter @ardyla/rootscript-core publish --access public"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
